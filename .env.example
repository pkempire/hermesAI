# ─── Core app URLs ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Supabase (auth + Postgres) ─────────────────────────────────────────────
# Get from your Supabase project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── LLM providers ──────────────────────────────────────────────────────────
# Hermes default model is OpenAI gpt-5-mini; Anthropic optional.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Discovery + research ───────────────────────────────────────────────────
EXA_API_KEY=
TAVILY_API_KEY=

# ─── Enrichment ─────────────────────────────────────────────────────────────
# Orangeslice is the primary enrichment client. Apollo + Hunter are fallbacks.
ORANGESLICE_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=

# ─── Optional scrape / send-volume providers ────────────────────────────────
APIFY_API_TOKEN=
INSTANTLY_API_KEY=
AGENTMAIL_API_KEY=

# ─── Google / Gmail OAuth ───────────────────────────────────────────────────
# Used for Gmail send + Google sign-in. Configure both at
# https://console.cloud.google.com/apis/credentials .
# Authorized redirect URIs MUST include:
#   http://localhost:3000/auth/oauth
#   https://YOUR_PROD_DOMAIN/auth/oauth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Billing (Stripe) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_CHECKOUT_URL=

# ─── Redis / cache / rate limit (Upstash recommended) ───────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional: REDIS_URL pointing to a self-hosted instance flips USE_LOCAL_REDIS.
USE_LOCAL_REDIS=false
REDIS_URL=

# ─── Feature flags ──────────────────────────────────────────────────────────
SKIP_QUOTA_CHECK=false
NEXT_PUBLIC_ENABLE_SAVE_CHAT_HISTORY=true
NEXT_PUBLIC_ENABLE_SHARE=true

# ─── Development ────────────────────────────────────────────────────────────
NODE_ENV=development
